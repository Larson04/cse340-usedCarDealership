<%- include('./partials/header.ejs') %>
<main>
    <!-- HERO SECTION -->
    <header class="hero">
        <div class="hero-content">
            <h1>Quality Used Cars You Can Trust</h1>
            <p>Affordable, reliable vehicles for every budget. Browse our inventory or schedule a test drive today.</p>
            
            <div class="hero-buttons">
                <a href="/inventory" class="button">View Inventory</a>
                <a href="/contact" class="button outline">Contact Us</a>
            </div>
        </div>
    </header>

    <!-- ABOUT -->
    <section class="about">
        <h2>About Us</h2>
        <p>
            Welcome to <strong>Hometown Motors</strong>, your trusted source for quality pre-owned vehicles.
            We offer a wide selection of cars, trucks, and SUVs at competitive prices.
        </p>
        <p>
            Our mission is to make your car-buying experience easy, transparent, and stress-free.
        </p>
    </section>

    <!-- FEATURED INVENTORY -->
    <h2>Featured Vehicles</h2>
    <section class="featured-vehicles">
        <div class="featured-grid">
            <% featuredVehicles.forEach(vehicle => { %>
            <div class="vehicle-card">
                <a href="/inventory/<%= vehicle.id %>">
                    <h3><%= vehicle.year %> <%= vehicle.make %> <%= vehicle.model %></h3>
                    <img class="vehicle-image" src="<%= vehicle.image %>" alt="<%= vehicle.alt || vehicle.year + ' ' + vehicle.make + ' ' + vehicle.model %>">
                </a>
                <div class="vehicle-info">
                    <p class="description"><%= vehicle.description %></p>
                    <p class="mileage">Mileage: <%= vehicle.mileage %></p>
                    <p class="price">$<%= vehicle.price.toLocaleString() %></p>
                    <p class="date">Created at: <%= vehicle.createdAt %> | Updated At:<%= vehicle.updatedAt %></p>
                </div>
                
            </div>
            <% }) %>
        </div>
    </section>

    <div class="info-container">
        <!-- WHY CHOOSE US -->
        <section class="why-us">
            <h2>Why Choose Us</h2>
            <ul>
                <li>★ Thoroughly inspected, reliable vehicles</li>
                <li>★ Competitive, transparent pricing</li>
                <li>★ Financing options for all credit types</li>
                <li>★ Friendly, no-pressure sales team</li>
                <li>★ Trusted by local customers</li>
            </ul>
        </section>

        <!-- SERVICES -->
        <section class="services">
            <h2>Our Services</h2>
            <ul>
                <li>★ Vehicle trade-ins</li>
                <li>★ Maintenance and service referrals</li>
                <li>★ Extended warranties</li>
                <li>★ Vehicle history reports</li>
            </ul>
        </section>

        <!-- REVIEWS -->
        <section class="reviews">
            <h2>Customer Reviews</h2>
            <div class="review">
                <p>“Great experience! The process was smooth and the staff was very helpful.”</p>
            </div>
            <div class="review">
                <p>“Found exactly what I needed at a great price.”</p>
            </div>
            <div class="review">
                <p>“Honest dealership with quality cars.”</p>
            </div>
        </section>

        <!-- FINAL CTA -->
        <section class="cta">
            <h2>Ready to find your next car?</h2>
            <div class="cta-links">
                <a href="/inventory">Browse Inventory</a> |
                <a href="/contact">Contact Us</a>
            </div>
        </section>
    </div>
</main>
<%- include('./partials/footer.ejs') %>