<%- include('../../partials/header.ejs') %>

<main>
    <h1><%= title %></h1>

    <% if (locals.flash && flash.error) { %>
        <% flash.error.forEach(err => { %>
            <p style="color:red;"><%= err %></p>
        <% }) %>
    <% } %>

    <form action="/reviews/<%= review.id %>/edit" method="POST">
        <div>
            <label>Vehicle</label>
            <input type="text" value="<%= review.vehicle %>" disabled>
        </div>

        <div>
            <label for="rating">Rating (1-5)</label>
            <input type="number" name="rating" id="rating" min="1" max="5" value="<%= review.rating %>" required>
        </div>

        <div>
            <label for="review">Review</label>
            <textarea name="review" id="review" rows="5" required><%= review.review %></textarea>
        </div>

        <button type="submit">Update Review</button>
    </form>
</main>

<%- include('../../partials/footer.ejs') %>