<%- include('../../partials/header.ejs') %>

<main>
    <h1><%= title %></h1>

    <% if (locals.flash && flash.success) { %>
        <% flash.success.forEach(msg => { %>
            <p style="color:green;"><%= msg %></p>
        <% }) %>
    <% } %>

    <% if (locals.flash && flash.error) { %>
        <% flash.error.forEach(msg => { %>
            <p style="color:red;"><%= msg %></p>
        <% }) %>
    <% } %>

    <% if (['admin', 'employee'].includes(user.roleName)) { %>
        <form method="GET">
            <label for="userFilter">Filter by User:</label>
            <select name="userId" id="userFilter">
                <option value="">All Users</option>
                <% allUsers.forEach(u => { %>
                    <option value="<%= u.id %>" <%= filter.userId == u.id ? 'selected' : '' %>><%= u.name %></option>
                <% }) %>
            </select>

            <label for="dateFilter">Filter by Date:</label>
            <input type="date" name="date" id="dateFilter" value="<%= filter.date || '' %>">

            <button type="submit">Filter</button>
        </form>
    <% } %>

    <table border="1" cellpadding="5" cellspacing="0">
        <thead>
            <tr>
                <% if (['admin', 'employee'].includes(user.roleName)) { %>
                    <th>User</th>
                <% } %>
                <th>Vehicle</th>
                <th>Rating</th>
                <th>Review</th>
                <th>Date</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            <% reviews.forEach(r => { %>
                <tr>
                    <% if (['admin', 'employee'].includes(user.roleName)) { %>
                        <td><%= r.userName %></td>
                    <% } %>
                    <td><%= r.vehicle %></td>
                    <td><%= r.rating %></td>
                    <td><%= r.review %></td>
                    <td><%= r.dateSubmitted.toDateString() %></td>
                    <td>
                        <a href="/reviews/<%= r.id %>/edit">Edit</a>
                        <form action="/reviews/<%= r.id %>/delete" method="POST" style="display:inline;" onsubmit="return confirm('Are you sure?');">
                            <button type="submit">Delete</button>
                        </form>
                    </td>
                </tr>
            <% }) %>
        </tbody>
    </table>
</main>

<%- include('../../partials/footer.ejs') %>