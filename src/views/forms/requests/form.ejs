<%- include('../../partials/header.ejs') %>

<main>
    <h1><%= title %></h1>

    <% if (locals.flash && flash.error) { %>
        <% flash.error.forEach(err => { %>
            <p style="color:red;"><%= err %></p>
        <% }) %>
    <% } %>

    <form action="/reviews/new" method="POST">
        <div>
            <label for="vehicleId">Select Vehicle</label>
            <select name="vehicleId" id="vehicleId">
                <% vehicles.forEach(vehicle => { %>
                    <option value="<%= vehicle.id %>"><%= vehicle.make %> <%= vehicle.model %> (<%= vehicle.year %>)</option>
                <% }) %>
            </select>
        </div>

        <div>
            <label for="rating">Rating (1-5)</label>
            <input type="number" name="rating" id="rating" min="1" max="5" required>
        </div>

        <div>
            <label for="review">Review</label>
            <textarea name="review" id="review" rows="5" placeholder="Write your review here..." required></textarea>
        </div>

        <button type="submit">Submit Review</button>
    </form>
</main>

<%- include('../../partials/footer.ejs') %>