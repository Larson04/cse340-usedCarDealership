<%- include('../../partials/header.ejs') %>

<main class="reviews-container">
    <h1><%= title %></h1>
    <p>
       Leave a review for one of our vehicles.
    </p>

    <form method="POST" action="/reviews" class="review-form">
        <!-- Make field -->
        <div class="form-group">
            <label for="make">Make</label>
            <input type="text" id="make"  name="make" placeholder="Enter the make" 
            minlength="2" required>
        </div>

        <!-- Model field -->
        <div class="form-group">
            <label for="model">Model</label>
            <input type="text" id="model" name="model" placeholder="Enter the model" minlength="2" required>
        </div>

        <!-- Year field -->
        <div class="form-group">
            <label for="year">Year</label>
            <input type="text" id="year" name="year" placeholder="Enter the year" minlength="2" required>
        </div>
        
        <div class="form-group">
            <label for="comment">Comment</label>
            <textarea id="comment" name="comment" rows="6" 
            placeholder="Please provide details about the vehicle" 
            minlength="10" required></textarea>
        </div>

        <div class="form-group rating">
            <input type="radio" name="rating" id="star5" value="5" required>
            <label for="star5">★</label>

            <input type="radio" name="rating" id="star4" value="4">
            <label for="star4">★</label>

            <input type="radio" name="rating" id="star3" value="3">
            <label for="star3">★</label>

            <input type="radio" name="rating" id="star2" value="2">
            <label for="star2">★</label>

            <input type="radio" name="rating" id="star1" value="1">
            <label for="star1">★</label>
        </div>

        <!-- Submit button -->
         <button type="submit">Submit</button>
    </form>
</main>

<%- include('../../partials/footer.ejs') %>