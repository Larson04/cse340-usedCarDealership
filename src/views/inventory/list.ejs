<%- include('../partials/header.ejs') %>
<main>
    <h1>Vehicle Inventory</h1>

    <!-- Sort Options -->
    <div class="filter-buttons">
        <p>Sort by:</p>
        <a href="?sort=category" class="filter-button <%= currentSort === 'category' ? 'active' : '' %>">Category</a> |
        <a href="?sort=make" class="filter-button <%= currentSort === 'make' ? 'active' : '' %>">Make</a> |
        <a href="?sort=model" class="filter-button <%= currentSort === 'model' ? 'active' : '' %>">Model</a> |
        <a href="?sort=year" class="filter-button <%= currentSort === 'year' ? 'active' : '' %>">Year</a> |
        <a href="?sort=price" class="filter-button <%= currentSort === 'price' ? 'active' : '' %>">Price</a>
    </div>

    <!-- Vehicle List -->
    <div class="vehicle-grid">
        <% vehicles.forEach(vehicle => { %>
            <div class="vehicle-card">
                <a href="/inventory/<%= vehicle.id %>">
                    <img 
                        class="vehicle-image"
                        src="<%= vehicle.image %>" 
                        alt="<%= vehicle.alt || vehicle.year + ' ' + vehicle.make + ' ' + vehicle.model %>">
                    <h2><%= vehicle.year %> <%= vehicle.make %> <%= vehicle.model %></h2>
                </a>
                <div class="vehicle-info">
                    <p class="category">Category: <%= vehicle.category %></p>
                    <p class="mileage">Mileage: <%= vehicle.mileage.toLocaleString() %> miles</p>
                    <p class="price">Price: $<%= vehicle.price.toLocaleString() %></p>
                    <p class="date">Created at: <%= vehicle.createdAt %> | Updated At:<%= vehicle.updatedAt %></p>
                </div>
            </div>
        <% }) %>
    </div>
</main>
<%- include('../partials/footer.ejs') %>